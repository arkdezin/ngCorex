{
  "schematics": {
    "ng-add": {
      "description": "Add ngCorex to an Angular project",
      "factory": "./dist/ng-add/index.js#ngAdd",
      "schema": "./dist/ng-add/schema.json",
      "externalDependencies": [
        "@ngcorex/cli"
      ]
    },
    "ng-update": {
      "description": "Update ngCorex to the latest version",
      "factory": "./dist/ng-update/index.js#ngUpdate",
      "schema": "./dist/ng-update/schema.json"
    }
  }
}
